---
import { characters, tierColors } from '../../data/game-data';

const tierOrder = ['Starter', 'Mid', 'Late', 'Endgame', 'Secret'];
---

<div class="not-content" style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-bottom:1.25rem">
  {tierOrder.map(tier => (
    <span style="font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:0.35rem">
      <span style={`display:inline-block;width:8px;height:8px;border-radius:50%;background:${tierColors[tier]}`}></span>
      {tier}
    </span>
  ))}
</div>

<div class="not-content" style="display:flex;flex-direction:column;gap:0.75rem">
  {characters.map((c, i) => (
    <div style="background:var(--sl-color-gray-6);border:1px solid var(--sl-color-gray-5);border-radius:8px;padding:1rem 1.25rem;display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem 1.5rem;transition:border-color 0.2s">
      <div style="display:flex;align-items:center;gap:0.6rem;min-width:200px">
        <span style="font-size:0.78rem;font-weight:700;color:var(--sl-color-gray-3);min-width:1.5rem">#{i+1}</span>
        <strong style="font-size:1rem;color:var(--sl-color-white)">{c.name}</strong>
        <span style={`font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:10px;background:rgba(255,255,255,0.06);color:${tierColors[c.tier]}`}>{c.tier}</span>
      </div>
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;flex:1;min-width:300px">
        <div><span style="font-size:0.72rem;color:var(--sl-color-gray-3)">Effect:</span> <span style="color:#14b8a6;font-size:0.88rem">{c.effect}</span></div>
        <div><span style="font-size:0.72rem;color:var(--sl-color-gray-3)">Trigger:</span> <span style="font-size:0.88rem" set:html={c.trigger} /></div>
        <div><span style="font-size:0.72rem;color:var(--sl-color-gray-3)">Dur:</span> <span style="font-size:0.85rem">{c.dur}s</span></div>
      </div>
      <div style="margin-left:auto;display:flex;align-items:center;gap:0.75rem;flex-shrink:0">
        <span style="font-size:0.75rem;color:var(--sl-color-gray-3)">{c.unlock}</span>
        <span style="font-size:0.75rem;padding:0.2rem 0.55rem;border-radius:6px;background:rgba(255,255,255,0.06);color:var(--sl-color-gray-2)">{c.cost} Mana</span>
      </div>
    </div>
  ))}
</div>
