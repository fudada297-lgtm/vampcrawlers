---
import { relics, relicTierColors } from '../../data/game-data';
---

<div class="not-content" style="display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:1.25rem">
  {Object.entries(relicTierColors).map(([tier, color]) => (
    <span style="font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:0.35rem">
      <span style={`display:inline-block;width:8px;height:8px;border-radius:50%;background:${color}`}></span>
      {tier}
    </span>
  ))}
</div>

<div class="not-content" style="display:flex;flex-direction:column;gap:0.5rem">
  {relics.map((r, i) => (
    <div style="background:var(--sl-color-gray-6);border:1px solid var(--sl-color-gray-5);border-radius:8px;padding:1rem 1.25rem;display:flex;flex-wrap:wrap;align-items:center;gap:0.5rem 1.5rem">
      <div style="flex:1;min-width:250px">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.25rem">
          <span style="font-size:0.78rem;font-weight:700;color:var(--sl-color-gray-3)">#{i+1}</span>
          <strong style="font-size:1rem;color:var(--sl-color-white)">{r.name}</strong>
          <span style={`font-size:0.7rem;padding:0.1rem 0.5rem;border-radius:10px;background:rgba(255,255,255,0.06);color:${relicTierColors[r.tier]}`}>{r.tier}</span>
        </div>
        <p style="font-size:0.9rem;color:var(--sl-color-gray-3);margin:0" set:html={r.effect} />
      </div>
      <div style="text-align:right;flex-shrink:0">
        <span style="font-size:0.85rem;font-weight:600;color:var(--sl-color-white)">{r.location}</span>
        {r.note && <p style="font-size:0.72rem;color:var(--sl-color-gray-3);margin:0.25rem 0 0">{r.note}</p>}
      </div>
    </div>
  ))}
</div>
