---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <SEO title={title} description={description} canonical={canonical} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    /* ====== Design System ====== */
    :root {
      --crimson: #e94560;
      --crimson-light: #f25a72;
      --crimson-glow: rgba(233,69,96,0.15);
      --crimson-glow-strong: rgba(233,69,96,0.3);
      --gold: #f0a500;
      --gold-light: #f8c940;
      --green: #10b981;
      --blue: #3b82f6;
      --purple: #8b5cf6;
      --yellow: #f59e0b;
      --teal: #2dd4bf;
      --amber: #fbbf24;

      --bg-root: #06060b;
      --bg-surface: #0c0c16;
      --bg-card: #111122;
      --bg-card-hover: #181830;
      --bg-elevated: #1a1a35;
      --border-subtle: #1e1e3a;
      --border-default: #2a2a4a;
      --border-hover: rgba(233,69,96,0.35);

      --text-primary: #e8e8f0;
      --text-secondary: #a0a0b8;
      --text-muted: #6b6b80;

      --radius-sm: 6px;
      --radius: 10px;
      --radius-lg: 14px;
      --radius-xl: 18px;

      --shadow-sm: 0 2px 8px rgba(0,0,0,0.4);
      --shadow-md: 0 8px 24px rgba(0,0,0,0.5);
      --shadow-lg: 0 16px 40px rgba(0,0,0,0.6);
      --shadow-glow: 0 4px 20px var(--crimson-glow);
      --shadow-glow-lg: 0 8px 40px var(--crimson-glow);

      --font: 'Inter', 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
      --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* ====== Reset ====== */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    html{scroll-behavior:smooth;font-size:16px}

    body{
      font-family:var(--font);
      background:var(--bg-root);
      color:var(--text-primary);
      line-height:1.7;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
    }

    body::before{
      content:'';
      position:fixed;inset:0;
      background:
        radial-gradient(ellipse at 20% 0%, rgba(233,69,96,0.04) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 100%, rgba(233,69,96,0.03) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(240,165,0,0.02) 0%, transparent 70%);
      pointer-events:none;z-index:0;
    }

    a{color:var(--crimson);text-decoration:none;transition:all var(--transition)}
    a:hover{color:var(--crimson-light)}

    /* ====== Scrollbar ====== */
    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:var(--bg-root)}
    ::-webkit-scrollbar-thumb{background:var(--border-default);border-radius:3px}
    ::-webkit-scrollbar-thumb:hover{background:var(--crimson)}

    /* ====== Utility ====== */
    .wrap{max-width:1200px;margin:0 auto;padding:0 1.5rem;position:relative;z-index:1}

    /* ====== Header ====== */
    .header{
      background:linear-gradient(180deg, rgba(12,12,22,0.98) 0%, rgba(12,12,22,0.92) 100%);
      backdrop-filter:blur(16px);
      border-bottom:1px solid var(--border-subtle);
      padding:0;position:sticky;top:0;z-index:30;
    }
    .header-inner{
      display:flex;align-items:center;justify-content:space-between;
      height:60px;max-width:1200px;margin:0 auto;padding:0 1.5rem;
    }
    .logo{
      display:flex;align-items:center;gap:0.5rem;font-size:1.15rem;font-weight:800;
      color:var(--text-primary);letter-spacing:-0.01em;transition:opacity var(--transition);
    }
    .logo:hover{opacity:0.85;color:var(--text-primary)}
    .logo-icon{
      width:32px;height:32px;background:linear-gradient(135deg, var(--crimson), #b91c1c);
      border-radius:8px;display:flex;align-items:center;justify-content:center;
      font-size:1rem;color:#fff;box-shadow:0 0 12px rgba(233,69,96,0.3);
    }
    .logo-accent{color:var(--crimson)}

    .nav-desktop{display:flex;gap:2px}
    .nav-desktop a{
      padding:0.4rem 0.9rem;border-radius:var(--radius-sm);font-size:0.875rem;
      font-weight:500;color:var(--text-secondary);transition:all var(--transition);
      position:relative;
    }
    .nav-desktop a:hover{color:var(--text-primary);background:rgba(255,255,255,0.04)}
    .nav-desktop a.active{color:var(--crimson);background:rgba(233,69,96,0.08)}

    /* ====== Mobile Nav ====== */
    .hamburger{display:none;background:none;border:none;color:var(--text-primary);cursor:pointer;padding:6px}
    .hamburger svg{width:24px;height:24px}

    @media(max-width:768px){
      .hamburger{display:block}
      .nav-desktop{display:none}
    }

    /* ====== Sidebar ====== */
    .wiki-layout{display:grid;grid-template-columns:230px 1fr;gap:2.5rem;padding:2rem 0}

    .sidebar{position:sticky;top:5rem;align-self:start;display:flex;flex-direction:column;gap:2px}
    .sidebar-group-label{
      font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;
      color:var(--text-muted);padding:0.5rem 0.75rem 0.25rem;
    }
    .sidebar-link{
      display:flex;align-items:center;gap:0.6rem;padding:0.55rem 0.75rem;
      border-radius:var(--radius-sm);color:var(--text-secondary);font-size:0.875rem;
      font-weight:500;transition:all var(--transition);border-left:2px solid transparent;
    }
    .sidebar-link:hover{
      background:rgba(233,69,96,0.06);color:var(--text-primary);
      transform:translateX(3px);border-left-color:var(--crimson);
    }
    .sidebar-link svg{width:18px;height:18px;flex-shrink:0;opacity:0.6;transition:opacity var(--transition)}
    .sidebar-link:hover svg{opacity:1;color:var(--crimson)}

    /* Mobile sidebar overlay */
    .sidebar-overlay{display:none}
    @media(max-width:768px){
      .wiki-layout{display:block}
      .sidebar{
        position:fixed;top:0;left:0;width:270px;height:100vh;
        background:var(--bg-surface);z-index:40;padding:1.5rem;
        overflow-y:auto;transform:translateX(-100%);transition:transform 0.25s ease;
        border-right:1px solid var(--border-subtle);
      }
      .sidebar.open{transform:translateX(0)}
      .sidebar-overlay{
        display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);
        z-index:39;backdrop-filter:blur(2px);
      }
      .sidebar-overlay.open{display:block}
    }

    /* ====== Hero ====== */
    .hero{
      position:relative;overflow:hidden;
      background:linear-gradient(135deg, rgba(12,12,22,0.95), rgba(20,10,30,0.95));
      border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:2.5rem 2.5rem 2rem;margin-bottom:2rem;
    }
    .hero::before{
      content:'';position:absolute;top:0;right:0;width:300px;height:300px;
      background:radial-gradient(circle, rgba(233,69,96,0.12) 0%, transparent 70%);
      pointer-events:none;
    }
    .hero::after{
      content:'';position:absolute;bottom:-1px;left:0;right:0;height:2px;
      background:linear-gradient(90deg, transparent, var(--crimson), transparent);
    }
    .hero-inner{position:relative;z-index:1}
    .hero h1{font-size:2.5rem;font-weight:900;color:#fff;margin-bottom:0.5rem;line-height:1.15;letter-spacing:-0.02em}
    .hero h1 .highlight{background:linear-gradient(135deg, var(--crimson), var(--crimson-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero p{color:var(--text-secondary);max-width:600px;font-size:1rem;line-height:1.6}
    .hero .badges{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:1.25rem}
    .badge{
      font-size:0.75rem;font-weight:500;
      background:rgba(233,69,96,0.08);color:var(--crimson-light);
      padding:0.35rem 0.85rem;border-radius:20px;
      border:1px solid rgba(233,69,96,0.15);
      letter-spacing:0.01em;
    }

    @media(max-width:768px){
      .hero{padding:1.75rem 1.5rem 1.5rem}
      .hero h1{font-size:1.75rem}
    }

    /* ====== Cards ====== */
    .card{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1.5rem;
      box-shadow:var(--shadow-sm);transition:all var(--transition);
    }
    .card:hover{box-shadow:var(--shadow-md);border-color:var(--border-hover);transform:translateY(-2px)}

    .card-link{
      display:block;background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1.5rem;
      box-shadow:var(--shadow-sm);transition:all var(--transition);
      cursor:pointer;color:inherit;position:relative;overflow:hidden;
    }
    .card-link::before{
      content:'';position:absolute;inset:0;opacity:0;
      background:radial-gradient(ellipse at top right, var(--crimson-glow), transparent 70%);
      transition:opacity var(--transition);
    }
    .card-link:hover::before{opacity:1}
    .card-link:hover{box-shadow:var(--shadow-glow);border-color:var(--crimson);transform:translateY(-3px)}
    .card-link:hover{color:inherit}
    .card-link>*{position:relative;z-index:1}
    .card-link .card-icon{
      font-size:2rem;margin-bottom:0.75rem;display:block;
    }
    .card-link h3{font-weight:700;color:var(--text-primary);margin-bottom:0.35rem;transition:color var(--transition)}
    .card-link:hover h3{color:var(--crimson)}
    .card-link p{color:var(--text-muted);font-size:0.88rem;line-height:1.5}

    /* Game-style icon card */
    .icon-card{
      width:40px;height:40px;border-radius:var(--radius-sm);
      display:flex;align-items:center;justify-content:center;
      font-size:1.25rem;margin-bottom:0.75rem;
    }
    .icon-red{background:rgba(233,69,96,0.12);color:var(--crimson)}
    .icon-blue{background:rgba(59,130,246,0.12);color:var(--blue)}
    .icon-green{background:rgba(16,185,129,0.12);color:var(--green)}
    .icon-purple{background:rgba(139,92,246,0.12);color:var(--purple)}
    .icon-gold{background:rgba(240,165,0,0.12);color:var(--gold)}
    .icon-teal{background:rgba(45,212,191,0.12);color:var(--teal)}

    /* ====== Sections ====== */
    .section{padding:1rem 0}
    .section-header{display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem}
    .section-header h2{font-size:1.3rem;font-weight:700;color:var(--text-primary)}
    .section-line{flex:1;height:1px;background:var(--border-subtle)}

    /* ====== Info Boxes ====== */
    .info-box,.tip-box,.warn-box,.danger-box{
      border-radius:var(--radius);padding:1rem 1.25rem;margin:1.25rem 0;
      font-size:0.92rem;line-height:1.6;
    }
    .info-box{
      background:rgba(59,130,246,0.06);border:1px solid rgba(59,130,246,0.15);
      border-left:3px solid var(--blue);
    }
    .tip-box{
      background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);
      border-left:3px solid var(--green);
    }
    .warn-box{
      background:rgba(245,158,11,0.06);border:1px solid rgba(245,158,11,0.15);
      border-left:3px solid var(--amber);
    }
    .danger-box{
      background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);
      border-left:3px solid #ef4444;
    }
    .info-box strong,.tip-box strong,.warn-box strong,.danger-box strong{color:var(--text-primary)}
    .info-box::before{content:'ℹ️ ';font-size:0.85rem}
    .tip-box::before{content:'💡 ';font-size:0.85rem}
    .warn-box::before{content:'⚠️ ';font-size:0.85rem}
    .danger-box::before{content:'🚫 ';font-size:0.85rem}

    .formula-box{
      background:rgba(233,69,96,0.05);border:1px solid rgba(233,69,96,0.15);
      border-radius:var(--radius);padding:1rem 1.5rem;text-align:center;
      font-weight:600;font-size:0.92rem;margin:1.25rem 0;color:var(--crimson-light);
    }

    /* ====== Tables ====== */
    .table-wrap{overflow-x:auto;margin:1rem 0;-webkit-overflow-scrolling:touch}
    table{width:100%;border-collapse:collapse;font-size:0.875rem}
    thead th{
      padding:0.7rem 0.9rem;font-weight:600;text-align:left;
      border-bottom:2px solid var(--crimson);color:var(--text-primary);
      background:rgba(233,69,96,0.04);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.04em;
    }
    tbody td{padding:0.65rem 0.9rem;border-bottom:1px solid var(--border-subtle);color:var(--text-secondary)}
    tbody tr{transition:background var(--transition)}
    tbody tr:hover{background:rgba(233,69,96,0.04)}
    tbody tr:nth-child(even){background:rgba(255,255,255,0.01)}
    tbody tr:nth-child(even):hover{background:rgba(233,69,96,0.05)}

    /* ====== TOC ====== */
    .toc{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius);padding:1.25rem 1.5rem;margin:1.25rem 0;
    }
    .toc-title{font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-muted);margin-bottom:0.75rem}
    .toc ol,.toc ul{padding-left:1.25rem;list-style:decimal}
    .toc li{margin-bottom:0.4rem;font-size:0.9rem}
    .toc a{color:var(--text-secondary);transition:all var(--transition)}
    .toc a:hover{color:var(--crimson);padding-left:4px}

    /* ====== Article Typography ====== */
    article h1{font-size:2.25rem;font-weight:900;color:#fff;margin-bottom:0.25rem;letter-spacing:-0.02em;line-height:1.2}
    article h2{
      font-size:1.35rem;font-weight:700;color:var(--text-primary);
      margin:2.5rem 0 0.75rem;padding-bottom:0.5rem;
      border-bottom:1px solid var(--border-subtle);letter-spacing:-0.01em;
    }
    article h3{font-size:1.05rem;font-weight:600;color:var(--text-primary);margin:1.5rem 0 0.5rem}
    article p{margin-bottom:0.8rem;color:var(--text-secondary);font-size:0.95rem}
    article ul,article ol{margin-bottom:1rem;padding-left:1.5rem}
    article li{margin-bottom:0.4rem;color:var(--text-secondary);font-size:0.93rem}
    article code{
      background:rgba(255,255,255,0.06);padding:0.15rem 0.4rem;border-radius:4px;
      font-size:0.88em;color:var(--crimson-light);border:1px solid var(--border-subtle);
    }
    article strong{color:var(--text-primary);font-weight:600}
    article sup{color:var(--crimson);font-size:0.7em}
    article .lead{font-size:1.05rem;color:var(--text-secondary);margin-bottom:2rem}

    @media(max-width:768px){
      article h1{font-size:1.7rem}
      article h2{font-size:1.15rem}
    }

    /* ====== Stat Grid ====== */
    .stat-grid{display:grid;grid-template-columns:repeat(auto-fill, minmax(120px, 1fr));gap:0.6rem}
    .stat-item{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius);padding:0.85rem 0.8rem;text-align:center;
      transition:all var(--transition);
    }
    .stat-item:hover{border-color:var(--crimson);box-shadow:var(--shadow-glow);transform:translateY(-1px)}
    .stat-value{font-size:1.4rem;font-weight:800;color:var(--crimson);line-height:1.1}
    .stat-label{font-size:0.72rem;color:var(--text-muted);margin-top:0.2rem;font-weight:500}

    /* ====== Buttons ====== */
    .btn{
      display:inline-flex;align-items:center;gap:0.4rem;padding:0.55rem 1.2rem;
      border-radius:var(--radius-sm);font-size:0.875rem;font-weight:600;border:none;
      cursor:pointer;transition:all var(--transition);font-family:var(--font);
    }
    .btn-primary{background:var(--crimson);color:#fff}
    .btn-primary:hover{background:var(--crimson-light);box-shadow:var(--shadow-glow);transform:translateY(-1px)}
    .btn-outline{background:transparent;border:1.5px solid var(--border-default);color:var(--text-secondary)}
    .btn-outline:hover{border-color:var(--crimson);color:var(--crimson);background:rgba(233,69,96,0.05)}
    .btn-sm{padding:0.4rem 0.8rem;font-size:0.8rem}

    /* ====== Ad Spot ====== */
    .ad-spot{
      background:var(--bg-card);border:1.5px dashed var(--border-subtle);
      border-radius:var(--radius-lg);padding:2rem;text-align:center;
      color:var(--text-muted);margin:1.5rem 0;font-size:0.85rem;
    }

    /* ====== Footer ====== */
    footer{
      border-top:1px solid var(--border-subtle);margin-top:3rem;
      padding:2rem 0;text-align:center;
    }
    footer p{color:var(--text-muted);font-size:0.82rem}
    footer a{color:var(--text-secondary);transition:color var(--transition)}
    footer a:hover{color:var(--crimson-light)}

    /* ====== Character Card ====== */
    .char-card{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1.25rem;transition:all var(--transition);
    }
    .char-card:hover{border-color:var(--border-hover);box-shadow:var(--shadow-md)}
    .char-card-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:0.75rem}
    .char-card-header h3{font-size:1rem;font-weight:700;color:var(--text-primary);margin:0}
    .char-card-cost{font-size:0.75rem;font-weight:600;background:rgba(139,92,246,0.1);color:var(--purple);padding:0.2rem 0.6rem;border-radius:12px}
    .char-card-body{display:grid;grid-template-columns:1fr 1fr;gap:0.4rem 1rem;font-size:0.85rem}
    .char-card-body dt{color:var(--text-muted);font-size:0.75rem;text-transform:uppercase;letter-spacing:0.04em}
    .char-card-body dd{color:var(--text-secondary)}
    @media(max-width:640px){.char-card-body{grid-template-columns:1fr}}

    /* ====== Dungeon Card ====== */
    .dungeon-card{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1rem 1.25rem;
      display:flex;align-items:center;justify-content:space-between;gap:1rem;
      flex-wrap:wrap;transition:all var(--transition);
    }
    .dungeon-card:hover{border-color:var(--border-hover);box-shadow:var(--shadow-sm)}
    .dungeon-rank{
      width:32px;height:32px;border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:0.78rem;font-weight:700;flex-shrink:0;
      background:var(--border-subtle);color:var(--text-muted);
    }
    .dungeon-info{flex:1;min-width:200px}
    .dungeon-info h3{font-size:0.95rem;font-weight:600;color:var(--text-primary);margin:0}
    .dungeon-info p{font-size:0.8rem;color:var(--text-muted);margin:0.15rem 0 0}
    .dungeon-meta{display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap}
    .dungeon-diff{font-size:0.78rem;color:var(--gold);letter-spacing:0.04em}
    .dungeon-reward{font-size:0.75rem;background:rgba(16,185,129,0.08);color:var(--green);padding:0.2rem 0.6rem;border-radius:12px}

    /* ====== Relic Card ====== */
    .relic-card{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1.25rem;transition:all var(--transition);
      display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;
    }
    .relic-card:hover{border-color:var(--gold);box-shadow:var(--shadow-md)}
    .relic-card h3{font-size:0.95rem;font-weight:700;color:var(--text-primary);margin:0}
    .relic-card p{font-size:0.85rem;color:var(--text-secondary);margin:0.25rem 0 0}
    .relic-location{font-size:0.75rem;background:var(--border-subtle);color:var(--text-muted);padding:0.25rem 0.65rem;border-radius:12px;white-space:nowrap}
    .relic-note{font-size:0.72rem;color:var(--text-muted);margin-top:0.25rem;text-align:right}

    /* ====== FAQ Item ====== */
    .faq-item{
      background:var(--bg-card);border:1px solid var(--border-subtle);
      border-radius:var(--radius-lg);padding:1.25rem;margin-bottom:0.75rem;
      transition:all var(--transition);
    }
    .faq-item:hover{border-color:var(--border-hover)}
    .faq-item h2{font-size:0.95rem;font-weight:700;color:var(--text-primary);margin:0 0 0.4rem;border:none;padding:0}
    .faq-item p{font-size:0.88rem;color:var(--text-secondary);margin:0}

    /* ====== Bottom Nav ====== */
    .bottom-nav{display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:2.5rem;padding-top:1.5rem;border-top:1px solid var(--border-subtle)}
    .bottom-nav a{font-size:0.88rem;font-weight:500}
    .bottom-nav .next{font-weight:600}

    /* ====== Breadcrumbs ====== */
    .breadcrumbs{font-size:0.82rem;color:var(--text-muted);margin-bottom:1rem}
    .breadcrumbs a{color:var(--text-secondary)}
    .breadcrumbs a:hover{color:var(--crimson)}
    .breadcrumbs span{color:var(--text-muted);margin:0 0.35rem}

    /* ====== Color tags ====== */
    .c-red{color:var(--crimson)}
    .c-blue{color:var(--blue)}
    .c-green{color:var(--green)}
    .c-purple{color:var(--purple)}
    .c-yellow{color:var(--gold)}
    .c-teal{color:var(--teal)}
    .c-gold{color:var(--gold)}

    /* ====== Grid Helpers ====== */
    .grid-2{display:grid;grid-template-columns:repeat(2, 1fr);gap:1rem}
    .grid-3{display:grid;grid-template-columns:repeat(3, 1fr);gap:1rem}
    .grid-4{display:grid;grid-template-columns:repeat(auto-fill, minmax(250px, 1fr));gap:1rem}

    @media(max-width:768px){
      .grid-2,.grid-3{grid-template-columns:1fr}
    }

    /* ====== Spacing ====== */
    .mt-2{margin-top:0.5rem}.mt-4{margin-top:1rem}.mt-6{margin-top:1.5rem}.mt-8{margin-top:2rem}
    .mb-2{margin-bottom:0.5rem}.mb-4{margin-bottom:1rem}.mb-6{margin-bottom:1.5rem}.mb-8{margin-bottom:2rem}
    .py-4{padding-top:1rem;padding-bottom:1rem}

    /* ====== Game Card Visual ====== */
    .game-card{
      display:inline-flex;align-items:center;justify-content:center;
      width:36px;height:36px;border-radius:6px;font-weight:700;font-size:0.8rem;
      border:2px solid;flex-shrink:0;
    }
    .game-card.red{background:rgba(233,69,96,0.1);border-color:rgba(233,69,96,0.3);color:var(--crimson)}
    .game-card.blue{background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.3);color:var(--blue)}
    .game-card.yellow{background:rgba(240,165,0,0.1);border-color:rgba(240,165,0,0.3);color:var(--gold)}
    .game-card.purple{background:rgba(139,92,246,0.1);border-color:rgba(139,92,246,0.3);color:var(--purple)}
    .game-card.teal{background:rgba(45,212,191,0.1);border-color:rgba(45,212,191,0.3);color:var(--teal)}

    /* ====== Progress bar ====== */
    .progress-bar{height:4px;background:var(--border-subtle);border-radius:2px;overflow:hidden;margin-top:0.5rem}
    .progress-fill{height:100%;background:var(--crimson);border-radius:2px;transition:width 0.6s ease}
  </style>
</head>
<body>
  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">V</span>
        Vampire<span class="logo-accent">Crawlers</span>
      </a>
      <button class="hamburger" id="menu-btn" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <nav class="nav-desktop" id="main-nav">
        {navLinks.map(link => (
          <a href={link.href} data-path={link.href}>{link.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <div class="sidebar-overlay" id="sidebar-overlay"></div>

  <div class="wrap">
    <div class="wiki-layout" style="padding-top:1rem">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-group-label">Navigation</div>
        {sidebarLinks.map(link => (
          <a href={link.href} class="sidebar-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d={link.icon}/>
            </svg>
            {link.label}
          </a>
        ))}
      </aside>
      <main class="content"><slot /></main>
    </div>
  </div>

  <footer>
    <div class="wrap">
      <p>Vampire Crawlers Guide &mdash; Unofficial fan resource. Not affiliated with poncle.</p>
      <p style="margin-top:0.25rem;font-size:0.75rem;color:var(--text-muted)">
        All game content, names, and assets are property of poncle.
      </p>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const content = document.querySelector('.content');

    function openMenu(){ sidebar.classList.add('open'); overlay.classList.add('open'); }
    function closeMenu(){ sidebar.classList.remove('open'); overlay.classList.remove('open'); }

    menuBtn.addEventListener('click', () => sidebar.classList.contains('open') ? closeMenu() : openMenu());
    overlay.addEventListener('click', closeMenu);
    content.addEventListener('click', (e) => {
      if(sidebar.classList.contains('open') && !e.target.closest('.sidebar')) closeMenu();
    });

    // Highlight active nav
    const currentPath = window.location.pathname;
    document.querySelectorAll('#main-nav a').forEach(a => {
      if(a.getAttribute('data-path') === currentPath || (currentPath.startsWith('/guides/') && a.getAttribute('data-path') !== '/' && currentPath.includes(a.getAttribute('data-path')))){
        a.classList.add('active');
      }
    });
  </script>
</body>
</html>
