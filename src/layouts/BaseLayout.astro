---
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <SEO title={title} description={description} canonical={canonical} />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{crimson:{50:'#fef2f2',100:'#fee2e2',200:'#fecaca',400:'#f87171',500:'#ef4444',600:'#dc2626',700:'#b91c1c',800:'#991b1b',900:'#7f1d1d'}}}}};</script>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen antialiased">
  <header class="bg-gray-900 border-b border-gray-800 sticky top-0 z-20">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold text-white">Vampire<span class="text-red-500">Crawlers</span>.cc</a>
      <nav class="flex gap-4 sm:gap-6 text-sm font-medium text-gray-400">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <a href="/guides/beginners-guide" class="hover:text-white transition-colors">Beginner's Guide</a>
        <a href="/guides/best-builds" class="hover:text-white transition-colors">Best Builds</a>
        <a href="/guides/cards-tier-list" class="hover:text-white transition-colors">Cards</a>
      </nav>
    </div>
  </header>

  <main><slot /></main>

  <footer class="border-t border-gray-800 mt-12">
    <div class="max-w-6xl mx-auto px-4 py-8 text-center text-sm text-gray-500">
      <p>Vampire Crawlers Guide &mdash; Unofficial fan site. Not affiliated with poncle.</p>
      <p class="mt-1">&copy; 2026 VampCrawlers.cc</p>
    </div>
  </footer>
</body>
</html>
