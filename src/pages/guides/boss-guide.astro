---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Vampire Crawlers Boss Strategy Guide — How to Beat Every Boss (2026)';
const description = 'Complete boss strategy guide for Vampire Crawlers. Learn every boss attack pattern, weakness, and the best strategy to defeat them.';
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/boss-guide">
  <article class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">Boss Strategy Guide</h1>
    <p class="text-gray-400 mb-8">Every boss in Vampire Crawlers — attack patterns, weaknesses, and winning strategies.</p>

    <div class="space-y-6">
      {[
        { name: 'The Gatekeeper (Floor 5)', element: 'Neutral', hp: '~2,000', strategy: 'First boss, straightforward. Dodges his slow axe swings to the left. Punish after his 3-hit combo. Weak to all elements. AoE cards clear his skeleton adds.', drops: 'Rusty Key (unlocks Forge)' },
        { name: 'Lady Crimson (Floor 10)', element: 'Blood', hp: '~5,000', strategy: 'Teleports around the arena leaving blood pools. Stay mobile. When she channels Blood Ritual, burst her down — she takes 50% extra damage during this phase. Shadow cards counter her healing.', drops: 'Crimson Shard (relic crafting)' },
        { name: 'Frost Giant (Floor 15)', element: 'Ice', hp: '~8,000', strategy: 'Slow but hits hard. AoE ice slam with visible ground indicator — dodge sideways. Summons ice pillars that block movement. Fire and Lightning cards melt his ice shield. Keep distance.', drops: 'Frozen Core (unlocks Frostveil)' },
        { name: 'Shadow Twins (Floor 20)', element: 'Shadow', hp: '~4,000 each', strategy: 'Two bosses simultaneously. One twin takes reduced physical damage, the other reduced magic. Split your deck: bring both physical and magic cards. Kill them within 10 seconds of each other or the dead one revives.', drops: 'Shadow Essence' },
        { name: 'Storm Dragon (Floor 25)', element: 'Lightning', hp: '~12,000', strategy: 'Flies across the arena leaving lightning trails. Ground pound spawns lightning orbs that slowly chase you. Anti-lightning relics are crucial. Frost cards slow its attack speed significantly. Attack during landing recovery frames.', drops: 'Dragon Heart' },
        { name: 'The First Vampire (Floor 30 — Final Boss)', element: 'All', hp: '~20,000', strategy: 'Three phases. Phase 1: standard melee. Phase 2: enrages at 60% HP, summons blood meteors. Phase 3 at 30%: immune to one random element, avoid that element. Build a two-element deck. Save relics for Phase 3. Blood Pact + Crimson Slash combo is the meta.', drops: 'Vampire Crown (completion relic)' },
      ].map(boss => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
          <h2 class="text-lg font-bold text-red-400 mb-1">{boss.name}</h2>
          <div class="flex flex-wrap gap-3 text-xs text-gray-500 mb-3">
            <span>Element: {boss.element}</span><span>HP: {boss.hp}</span><span>Drops: {boss.drops}</span>
          </div>
          <p class="text-gray-400 text-sm">{boss.strategy}</p>
        </div>
      ))}
    </div>

    <div class="mt-6 pt-4 border-t border-gray-800 flex flex-wrap gap-3 text-sm">
      <a href="/guides/best-builds" class="text-red-400 hover:underline">Best Builds</a>
      <a href="/guides/cards-tier-list" class="text-red-400 hover:underline">Cards Tier List</a>
      <a href="/guides/beginners-guide" class="text-red-400 hover:underline">Beginner's Guide</a>
    </div>
  </article>
</BaseLayout>
