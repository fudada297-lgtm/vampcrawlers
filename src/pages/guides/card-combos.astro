---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Vampire Crawlers Card Combos & Synergies — Ultimate Guide (2026)';
const description = 'Master Vampire Crawlers card combinations and elemental synergies. Discover the most powerful card combos: Freeze+Shatter, Blood Pact+Crimson Slash, Mark+Assassinate, and more.';
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/card-combos">
  <article class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">Card Combos & Synergies</h1>
    <p class="text-gray-400 mb-8">The most powerful card combinations and elemental synergies in Vampire Crawlers.</p>

    <div class="space-y-6">
      {[
        { name: 'Freeze + Shatter', cards: 'Blizzard / Frost Nova → Shatter', effect: 'Freeze enemies first, then Shatter deals 300% damage to frozen targets. The highest single-target burst combo in the game. Works on bosses.' },
        { name: 'Blood Pact + Crimson Slash', cards: 'Blood Pact → Crimson Slash', effect: 'Blood Pact sacrifices 10% HP for 50% increased damage. Crimson Slash already heals. Net result: massive damage with self-healing. Core of the Blood DPS build.' },
        { name: 'Mark of Death + Shadow Strike', cards: 'Mark of Death → Shadow Strike', effect: 'Mark increases target damage taken by 40%. Shadow Strike teleports behind and deals bonus backstab damage. Combined: nearly one-shots elite enemies.' },
        { name: 'Overcharge + Chain Lightning', cards: 'Overcharge → Chain Lightning', effect: 'Overcharge doubles lightning damage at the cost of 25% more damage taken. Chain Lightning hits 4 targets. Clears entire screens instantly. High risk, high reward.' },
        { name: 'Vanish + Shadow Strike', cards: 'Vanish → Shadow Strike', effect: 'Vanish grants invulnerability and guarantees crit on next attack. Shadow Strike with crit = absurd burst. Essential for Shadow Assassin playstyle.' },
        { name: 'Frozen Armor + Blizzard', cards: 'Blizzard → Frozen Armor', effect: 'Frozen Armor gives shield based on number of frozen enemies. Cast Blizzard to freeze groups, then activate Frozen Armor. Can generate 500+ shield in one cast.', weight: 'Defensive' },
        { name: 'Vampiric Strike + Hemorrhage', cards: 'Vampiric Strike → Hemorrhage', effect: 'Hemorrhage is a stacking DoT (up to 5 stacks). Vampiric Strike heals 50% of damage. Together: continuous healing from the DoT ticks. Incredible sustain.', weight: 'Sustain' },
        { name: 'Static Field + Storm Call', cards: 'Static Field → Storm Call', effect: 'Static Field provides constant AoE damage aura. Storm Call adds targeted lightning strikes. Together they melt everything on screen. Best wave-clear combo.', weight: 'AoE' },
      ].map(combo => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <h2 class="text-lg font-bold text-white mb-1">{combo.name}</h2>
          <p class="text-xs text-red-400 mb-2">{combo.cards}</p>
          <p class="text-gray-400 text-sm">{combo.effect}</p>
        </div>
      ))}
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mt-6">
      <h2 class="text-lg font-bold text-white mb-3">Elemental Synergy Bonus</h2>
      <p class="text-gray-400 text-sm mb-2">Playing 3+ cards of the same element activates an elemental bonus:</p>
      <ul class="list-disc pl-5 space-y-1 text-gray-400 text-sm">
        <li><strong>3 Blood Cards:</strong> +15% lifesteal for 8 seconds</li>
        <li><strong>3 Frost Cards:</strong> Next hit freezes the target</li>
        <li><strong>3 Shadow Cards:</strong> +50% crit chance for 6 seconds</li>
        <li><strong>3 Lightning Cards:</strong> +30% attack speed for 8 seconds</li>
      </ul>
    </div>

    <div class="mt-6 pt-4 border-t border-gray-800 flex flex-wrap gap-3 text-sm">
      <a href="/guides/best-builds" class="text-red-400 hover:underline">Best Builds</a>
      <a href="/guides/cards-tier-list" class="text-red-400 hover:underline">Cards Tier List</a>
      <a href="/guides/beginners-guide" class="text-red-400 hover:underline">Beginner's Guide</a>
    </div>
  </article>
</BaseLayout>
