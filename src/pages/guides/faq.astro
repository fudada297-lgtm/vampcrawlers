---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Vampire Crawlers FAQ — Frequently Asked Questions';
const description = 'Common Vampire Crawlers questions: how to play, unlock characters, best cards, game mechanics, and more.';
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/faq">
  <article>
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-1">FAQ</h1>
    <p class="text-gray-500 mb-6">Frequently asked questions about Vampire Crawlers.</p>

    {[
      { q: 'What is Vampire Crawlers?', a: 'A turn-based deckbuilder roguelite from poncle, the creators of Vampire Survivors. Released April 21, 2026 on Steam, Xbox, PS5, and Switch.' },
      { q: 'Is it like Vampire Survivors?', a: 'No — Vampire Survivors is a real-time bullet heaven game. Vampire Crawlers is a turn-based card game. Different genre, same universe.' },
      { q: 'How many cards are in the game?', a: '80+ cards across 6 types: 37 Attack (Red), 7 Defense (Blue), 18 Stat Boost (Yellow), 6 Mana (Purple), 22 Character (Teal), and several Wild/Temporary cards.' },
      { q: 'How do I unlock new dungeons?', a: 'Most dungeons unlock by completing the previous dungeon in that chain. Some unlock by reaching a specific level (10 or 15) — you don\'t need to survive, just hit the level.' },
      { q: 'What are relics?', a: 'Permanent upgrades found hidden in breakable objects (barrels, crates) in dungeons. Once collected, they stay active forever. You can toggle them in the Museum.' },
      { q: 'What\'s the best starting strategy?', a: 'Clear Mad Forest first. Reach Level 10 there to unlock Inlaid Library. Collect the Combo Stack relic from the Tutorial. Buy characters at the Inn. Prioritize Mana cards early.' },
      { q: 'How do I get more characters?', a: 'Buy them at the Gorton Bell Inn in the Village using coins earned from dungeon runs. New characters unlock by completing specific dungeons or reaching milestones.' },
      { q: 'What is Combo Stack?', a: 'A relic that gives you a damage multiplier for playing cards in ascending mana cost order. Low cost → high cost = bigger combos = more damage.' },
      { q: 'How many players does it support?', a: 'Single player only. No multiplayer mode.' },
      { q: 'Is it on mobile?', a: 'No. Currently available on Steam, Xbox Series S|X, PlayStation 5, and Nintendo Switch.' },
      { q: 'How much does it cost?', a: '$14.99 USD on Steam, with occasional sales.' },
      { q: 'What are gems?', a: 'Gems (unlocked by the Gem Hammer relic) can be socketed into cards at the Blacksmith for permanent stat bonuses. The Lapidary Loupe relic lets you customize gem drops.' },
    ].map((item, i) => (
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-3">
        <h2 class="font-bold text-white mb-1">{i+1}. {item.q}</h2>
        <p class="text-gray-400 text-sm">{item.a}</p>
      </div>
    ))}

    <div class="flex flex-wrap gap-3 mt-8 pt-4 border-t border-gray-800 text-sm">
      <a href="/guides/beginners-guide" class="text-red-400 hover:underline font-medium">Beginner's Guide →</a>
      <a href="/guides/cards-list" class="text-red-400 hover:underline font-medium">Cards List →</a>
    </div>
  </article>
</BaseLayout>
