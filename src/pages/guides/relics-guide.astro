---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Vampire Crawlers Relics Guide — All 15 Relics, Effects & Locations';
const description = 'Complete Vampire Crawlers relics guide. All 15 relics with permanent effects, dungeon locations, and unlock requirements. Combo Stack, Grim Grimoire, Overkill and more.';

const relics = [
  { name: 'Combo Stack', effect: 'Play cards in ascending mana cost order for combo multiplier bonus', location: 'Tutorial', note: 'Received automatically' },
  { name: 'Milky Way Map', effect: 'Shows enemy positions on the mini-map', location: 'Default', note: 'Unlocks after first 2 dungeons' },
  { name: 'Rilevatore', effect: 'Shows weapon effect previews against enemies', location: 'Default', note: 'Unlocks after first 2 dungeons' },
  { name: 'Gem Hammer', effect: 'Unlock the ability to socket gems into cards', location: 'Mad Forest' },
  { name: 'Guiding Light', effect: 'Shows destructible light sources on mini-map', location: 'Inlaid Library' },
  { name: 'Grim Grimoire', effect: 'Pause menu shows discovered card evolutions & combos', location: 'Library West Wing' },
  { name: 'Polentir', effect: 'Unlock the Fortune Teller tent in the Village (Arcana system)', location: 'Furious Forest' },
  { name: 'Arcana Finder', effect: 'Random Arcana chests appear in dungeons', location: 'Library Sanctum' },
  { name: 'Stardust Anvil', effect: 'Unlock the Blacksmith in the Village — add gem slots to cards', location: 'Teeny Bridge' },
  { name: 'Overkill', effect: 'After beating a boss, keep attacking for bonus gold (cap: 500)', location: 'Teeny Bridge' },
  { name: 'Bomba Infernale', effect: 'One-click clear all enemies on Floor 1 of any completed dungeon', location: 'Dairy Plant' },
  { name: 'Ultimate Ultra Overkill', effect: 'Increase Overkill gold cap from 500 to 5,000', location: 'Curd Refinery' },
  { name: 'Lapidary Loupe', effect: 'Unlock Jeweler counter — adjust gem drop rates or ban specific gems', location: 'Gallo Tower' },
  { name: "Sorceress' Tears", effect: 'Adds a "Speed Up" button to the world map (fast mode)', location: 'Gallo Tower' },
  { name: 'Ovenkilt', effect: 'Overkill triggers on the last enemy of every encounter, but chests no longer give gold', location: 'Cappella Ultima', note: 'Final relic' },
];
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/relics-guide">
  <article>
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-1">Relics Guide</h1>
    <p class="text-gray-500 mb-6">All 15 relics — permanent upgrades, where to find them, and what they do.</p>

    <div class="tip-box"><strong>Important:</strong> Relics are permanent once collected. You can toggle them on/off in the Museum in the Village. No need to equip them.</div>

    <div class="space-y-3">
      {relics.map((r, i) => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <div class="flex items-center justify-between flex-wrap gap-2">
            <div>
              <h3 class="font-bold text-white">{i+1}. {r.name}</h3>
              <p class="text-sm text-gray-400 mt-0.5">{r.effect}</p>
            </div>
            <div class="text-right">
              <span class="text-xs bg-gray-800 text-gray-300 px-2 py-0.5 rounded">{r.location}</span>
              {r.note && <p class="text-xs text-gray-500 mt-0.5">{r.note}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex flex-wrap gap-3 mt-8 pt-4 border-t border-gray-800 text-sm">
      <a href="/guides/cards-list" class="text-red-400 hover:underline font-medium">Cards List →</a>
      <a href="/guides/dungeons-guide" class="text-red-400 hover:underline font-medium">Dungeons Guide →</a>
    </div>
  </article>
</BaseLayout>
