---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Vampire Crawlers How to Unlock All Characters — Complete Guide (2026)';
const description = 'How to unlock every character in Vampire Crawlers. Bloodfang, Frostveil, Shadowmancer, Stormcaller, and all hidden characters with unlock requirements.';
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/unlock-characters">
  <article class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">How to Unlock All Characters</h1>
    <p class="text-gray-400 mb-8">Complete guide to unlocking every playable character in Vampire Crawlers.</p>

    <div class="space-y-4">
      {[
        { name: 'Bloodfang', emoji: '🩸', how: 'Starter character — unlocked by default.', difficulty: 'Easy' },
        { name: 'Frostveil', emoji: '❄️', how: 'Clear Floor 10 with Bloodfang (any build).', difficulty: 'Easy' },
        { name: 'Shadowmancer', emoji: '🌑', how: 'Complete a run with at least 5 Shadow cards in your deck. Reach Floor 20.', difficulty: 'Medium' },
        { name: 'Stormcaller', emoji: '⚡', how: 'Deal 10,000 total Lightning damage across all runs. Tracks cumulatively.', difficulty: 'Medium' },
        { name: 'Crimson Lord', emoji: '🩸', how: 'Beat the final boss with Bloodfang on Hard difficulty.', difficulty: 'Hard' },
        { name: 'Frost Queen', emoji: '👑', how: 'Freeze 100 enemies in a single run with Frostveil.', difficulty: 'Hard' },
        { name: 'The Reaper', emoji: '💀', how: 'Hidden character. Die exactly on Floor 13 with any character. A secret door appears on your next run.', difficulty: 'Secret' },
        { name: 'Phoenix', emoji: '🔥', how: 'Complete a run without using any healing cards or Blood Altars. Self-imposed challenge.', difficulty: 'Very Hard' },
      ].map(char => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-lg font-bold text-white">{char.emoji} {char.name}</h2>
            <span class="text-xs px-2 py-0.5 rounded bg-gray-800 text-gray-400">{char.difficulty}</span>
          </div>
          <p class="text-gray-400 text-sm">{char.how}</p>
        </div>
      ))}
    </div>

    <div class="mt-6 pt-4 border-t border-gray-800 flex flex-wrap gap-3 text-sm">
      <a href="/guides/beginners-guide" class="text-red-400 hover:underline">Beginner's Guide</a>
      <a href="/guides/best-builds" class="text-red-400 hover:underline">Best Builds</a>
    </div>
  </article>
</BaseLayout>
