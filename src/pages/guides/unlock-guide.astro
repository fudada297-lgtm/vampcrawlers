---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Vampire Crawlers Unlock Guide — All Characters, Relics & Stages';
const description = 'How to unlock everything in Vampire Crawlers. All 22 characters, 15 relics, 15 stages with precise unlock requirements.';

const sections = [
  { title: 'Unlock Characters', items: [
    'Antonio, Arca, Cavallo, Christine, Clerici, Imelda, Mortaccio, Porta — Default',
    'Concetta, Gallo — Complete Gallo Tower',
    'Giovanna — Complete Library Sanctum',
    'Poppea — Complete Milk Factory',
    'Pugnala — Complete Berserk Wood',
    'MissingN0 — Hidden character (secret condition)',
    'Dommario, Gennaro, Krochi, Lama, O\'Sole, Pasqualina, Poe, Ramba — Various dungeon/level milestones',
  ]},
  { title: 'Unlock Relics', items: [
    'Combo Stack — Tutorial (automatic)',
    'Milky Way Map, Rilevatore — Complete first 2 dungeons',
    'Gem Hammer — Find in Mad Forest',
    'Guiding Light — Find in Inlaid Library',
    'Grim Grimoire — Find in Library West Wing',
    'Polentir — Find in Furious Forest',
    'Arcana Finder — Find in Library Sanctum',
    'Stardust Anvil, Overkill — Find in Teeny Bridge',
    'Bomba Infernale — Find in Dairy Plant',
    'Ultimate Ultra Overkill — Find in Curd Refinery',
    'Lapidary Loupe, Sorceress\' Tears — Find in Gallo Tower',
    'Ovenkilt — Find in Cappella Ultima',
  ]},
  { title: 'Unlock Stages', items: [
    'Mad Forest — Starting dungeon',
    'Inlaid Library — Reach Level 10 in Mad Forest',
    'Furious Forest — Complete Mad Forest',
    'Library West Wing — Complete Inlaid Library',
    'Teeny Bridge — Reach Level 15 in Inlaid Library',
    'Berserk Wood — Complete Furious Forest',
    'Library Sanctum — Complete Library West Wing',
    'Dairy Plant — Complete Teeny Bridge',
    'Milk Factory — Complete Dairy Plant',
    'Weeny Bridge — Reach Level 15 in Dairy Plant',
    'Curd Refinery — Complete Milk Factory',
    'Gallo Tower — Complete Weeny Bridge',
    'Meany Bridge — Defeat Giant Enemy Crab in Gallo Tower',
    'Capella Magna — Complete Meany Bridge',
    'Cappella Ultima — Complete Capella Magna',
  ]},
];
---

<BaseLayout title={title} description={description} canonical="https://vampcrawlers.cc/guides/unlock-guide">
  <article>
    <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-1">Unlock Guide</h1>
    <p class="text-gray-500 mb-6">Everything you can unlock in Vampire Crawlers and how to get it.</p>

    {sections.map(s => (
      <div class="mb-6">
        <h2 class="text-xl font-bold text-white mb-3">{s.title}</h2>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <ul class="space-y-1.5 text-gray-400 text-sm">
            {s.items.map(item => <li class="flex gap-2"><span class="text-red-500 mt-1">•</span> {item}</li>)}
          </ul>
        </div>
      </div>
    ))}

    <div class="flex flex-wrap gap-3 mt-8 pt-4 border-t border-gray-800 text-sm">
      <a href="/guides/characters-guide" class="text-red-400 hover:underline font-medium">Characters Guide →</a>
      <a href="/guides/relics-guide" class="text-red-400 hover:underline font-medium">Relics Guide →</a>
      <a href="/guides/dungeons-guide" class="text-red-400 hover:underline font-medium">Dungeons Guide →</a>
    </div>
  </article>
</BaseLayout>
