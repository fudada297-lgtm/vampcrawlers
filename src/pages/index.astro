---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Vampire Crawlers Wiki & Guide — Cards, Characters, Relics, Dungeons';
const description = 'Complete Vampire Crawlers guide: all 37 attack cards, 22 characters, 15 relics, 15 dungeons, unlock requirements, and beginner tips. Updated May 2026.';

const guides = [
  { emoji:'🎓', title:'Beginner\'s Guide', desc:'New to Vampire Crawlers? Learn the turn-based deckbuilder basics.', slug:'beginners-guide', color:'blue' },
  { emoji:'🃏', title:'Cards List', desc:'Complete catalog: 37 Attack, 7 Defense, 6 Mana, 18 Stat Boost cards.', slug:'cards-list', color:'red' },
  { emoji:'👤', title:'Characters', desc:'All 22 characters with stats, effects, and how to unlock them.', slug:'characters-guide', color:'green' },
  { emoji:'💎', title:'Relics Guide', desc:'15 relics with permanent effects and dungeon locations.', slug:'relics-guide', color:'cyan' },
  { emoji:'🗺️', title:'Dungeons', desc:'All 15 stages with unlock requirements and rewards.', slug:'dungeons-guide', color:'purple' },
  { emoji:'🔓', title:'Unlocks', desc:'How to unlock every character, relic, and stage.', slug:'unlock-guide', color:'yellow' },
  { emoji:'❓', title:'FAQ', desc:'Frequently asked questions about Vampire Crawlers.', slug:'faq', color:'gray' },
];
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={`{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Vampire Crawlers Guide",
    "url": "https://vampcrawlers.cc",
    "description": "${description}"
  }`} />

  <div class="bg-gradient-to-br from-red-900/40 via-gray-900 to-gray-950 border border-gray-800 rounded-xl p-8 mb-6">
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-2">Vampire Crawlers <span class="text-red-500">Wiki</span></h1>
      <p class="text-gray-400 max-w-2xl">Complete guide to poncle's turn-based deckbuilder. Released April 21, 2026 on Steam, Xbox, PS5 & Switch. Over 1 million players in the first week.</p>
      <div class="flex flex-wrap gap-2 mt-4">
        <span class="text-xs bg-gray-800 text-gray-400 px-2.5 py-1 rounded-full">Turn-Based Deckbuilder</span>
        <span class="text-xs bg-gray-800 text-gray-400 px-2.5 py-1 rounded-full">37 Attack Cards</span>
        <span class="text-xs bg-gray-800 text-gray-400 px-2.5 py-1 rounded-full">22 Characters</span>
        <span class="text-xs bg-gray-800 text-gray-400 px-2.5 py-1 rounded-full">15 Relics</span>
        <span class="text-xs bg-gray-800 text-gray-400 px-2.5 py-1 rounded-full">15 Dungeons</span>
      </div>
    </div>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
    {guides.map(g => (
      <a href={`/guides/${g.slug}`} class={`bg-gray-900 border border-gray-800 hover:border-${g.color}-500/50 rounded-xl p-5 group transition-all hover:bg-gray-800/50`}>
        <span class="text-2xl">{g.emoji}</span>
        <h3 class={`font-bold text-white mt-2 group-hover:text-${g.color}-400 transition-colors`}>{g.title}</h3>
        <p class="text-sm text-gray-500 mt-1">{g.desc}</p>
      </a>
    ))}
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-bold text-white mb-3">Game Overview</h2>
    <p class="text-gray-400 leading-relaxed">Vampire Crawlers is a casual turn-based deckbuilder with roguelite elements from poncle, the creators of Vampire Survivors. Build decks, explore dungeons, and unleash powerful combos. The game features color-coded cards — <span class="text-red-400">Attack (Red)</span>, <span class="text-blue-400">Defense (Blue)</span>, <span class="text-yellow-400">Stat Boost (Yellow)</span>, <span class="text-purple-400">Mana (Purple)</span>, <span class="text-teal-400">Character (Teal)</span>, and <span class="text-gray-400">Wild (White)</span>. Progress through 15 dungeons, unlock 22 characters, and collect 15 permanent relics.</p>
    <div class="stat-grid mt-4">
      <div class="stat-item"><div class="stat-value">37</div><div class="stat-label">Attack Cards</div></div>
      <div class="stat-item"><div class="stat-value">7</div><div class="stat-label">Defense Cards</div></div>
      <div class="stat-item"><div class="stat-value">22</div><div class="stat-label">Characters</div></div>
      <div class="stat-item"><div class="stat-value">15</div><div class="stat-label">Relics</div></div>
      <div class="stat-item"><div class="stat-value">15</div><div class="stat-label">Dungeons</div></div>
      <div class="stat-item"><div class="stat-value">6</div><div class="stat-label">Card Types</div></div>
    </div>
  </div>
</BaseLayout>
